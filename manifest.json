{
  "manifest_version": 3,
  "name": "DigIAna",
  "version": "2.0",
  "description": "DigIAna: Assistente de escrita inteligente com IA local para WhatsApp Web.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://web.whatsapp.com/*",
    "https://*.digisac.chat/*",
    "http://localhost:8080/*"
  ],
  "options_ui": {
    "page": "popup/popup.html",
    "open_in_tab": true
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://web.whatsapp.com/*",
        "https://*.digisac.chat/*"
      ],
      "js": ["content/content.js"],
      "css": ["content/styles.css"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
